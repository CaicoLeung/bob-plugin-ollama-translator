{
  "identifier": "bob-plugin-ollama-translator",
  "category": "translate",
  "version": "8.4.0",
  "name": "AI单词/翻译/百科解释",
  "summary": "支持多种AI服务（Ollama/OpenAI/Grok/Claude/Gemini等）的翻译和解释插件，可进行单词翻译、文本翻译及百科解释",
  "author": "Caico",
  "homepage": "https://github.com/CaicoLeung/bob-plugin-ollama-translator",
  "appcast": "https://raw.githubusercontent.com/CaicoLeung/bob-plugin-ollama-translator/main/appcast.json",
  "minBobVersion": "1.15.0",
  "options": [
    {
      "identifier": "service",
      "type": "menu",
      "title": "服务",
      "defaultValue": "ollama",
      "desc": "选择服务",
      "menuValues": [
        {
          "title": "Ollama",
          "value": "ollama"
        },
        {
          "title": "OpenAI",
          "value": "openai"
        },
        {
          "title": "Grok",
          "value": "grok"
        },
        {
          "title": "Claude",
          "value": "claude"
        },
        {
          "title": "DeepSeek",
          "value": "deepseek"
        },
        {
          "title": "Gemini",
          "value": "gemini"
        },
        {
          "title": "Zhipu",
          "value": "zhipu"
        },
        {
          "title": "其他",
          "value": "other"
        }
      ]
    },
    {
      "identifier": "baseUrl",
      "type": "text",
      "title": "Base URL",
      "desc": "选择其他服务时，请输入Base URL",
      "textConfig": {
        "type": "visible",
        "height": 40,
        "placeholderText": "例如: https://api.openai.com/v1/chat/completions"
      }
    },
    {
      "identifier": "openaiApiKey",
      "type": "text",
      "title": "OpenAI API KEY",
      "desc": "OpenAI 服务的 API KEY",
      "textConfig": {
        "placeholderText": "例如: sk-proj-1234567890"
      }
    },
    {
      "identifier": "grokApiKey",
      "type": "text",
      "title": "Grok API KEY",
      "desc": "Grok 服务的 API KEY",
      "textConfig": {
        "placeholderText": "例如: xai-1234567890"
      }
    },
    {
      "identifier": "claudeApiKey",
      "type": "text",
      "title": "Claude API KEY",
      "desc": "Claude 服务的 API KEY",
      "textConfig": {
        "placeholderText": "例如: sk-ant-1234567890"
      }
    },
    {
      "identifier": "deepseekApiKey",
      "type": "text",
      "title": "DeepSeek API KEY",
      "desc": "DeepSeek 服务的 API KEY",
      "textConfig": {
        "placeholderText": "例如: sk-1234567890"
      }
    },
    {
      "identifier": "geminiApiKey",
      "type": "text",
      "title": "Gemini API KEY",
      "desc": "Gemini 服务的 API KEY",
      "textConfig": {
        "placeholderText": "例如: AIzaSy..."
      }
    },
    {
      "identifier": "zhipuApiKey",
      "type": "text",
      "title": "Zhipu API KEY",
      "desc": "Zhipu (智谱AI) 服务的 API KEY",
      "textConfig": {
        "placeholderText": "例如: 5f3d2..."
      }
    },
    {
      "identifier": "otherApiKey",
      "type": "text",
      "title": "其他服务 API KEY",
      "desc": "选择「其他」服务时使用的 API KEY",
      "textConfig": {
        "placeholderText": "例如: sk-1234567890"
      }
    },
    {
      "identifier": "pattern",
      "type": "menu",
      "title": "模式",
      "defaultValue": "translate",
      "desc": "选择翻译模式或解释模式",
      "menuValues": [
        {
          "title": "翻译模式",
          "value": "translate"
        },
        {
          "title": "解释模式",
          "value": "interpret"
        }
      ]
    },
    {
      "identifier": "prompt",
      "type": "text",
      "title": "prompt",
      "desc": "自定义prompt模式，为空时使用默认prompt。源语言为{sourceLang}，目标语言为{targetLang}，原文为{sourceText}。",
      "textConfig": {
        "type": "visible",
        "height": 100,
        "placeholderText": "请输入prompt"
      }
    },
    {
      "identifier": "wordPrompt",
      "type": "text",
      "title": "单词模式 prompt",
